// Expected exit code: 0
// Expected output:
// 6
// 3
// -4
// -1
// 0
// 1
import math

show math.gcd(18, 24)

// Truncated division: 10 / 3 = 3. Floor division: 10 // 3 = 3
show math.floor_div(10, 3)

// Truncated division: -10 / 3 = -3. Floor division: -10 // 3 = -4
show math.floor_div(-10, 3)

show math.sign(-100)
show math.sign(0)
show math.sign(42)
