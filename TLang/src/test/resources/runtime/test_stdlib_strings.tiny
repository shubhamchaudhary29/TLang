// Expected exit code: 0
// Expected output:
// 10, true, hello
// aaaaa
// olleh
// true
// false
// --abc
// abc--
// 123
// -45
// 789
import strings

let parts be [10, true, "hello"]
show strings.join(parts, ", ")

show strings.repeat("a", 5)
show strings.reverse("hello")

show strings.isBlank("   \n\t  ")
show strings.isBlank("  abc  ")

show strings.padLeft("abc", 5, "-")
show strings.padRight("abc", 5, "-")

show strings.toNumber("123")
show strings.toNumber("-45")
show strings.toNumber("  789  ")
