// Expected output:
// 0
// 1
// 1
// 1
// 3
// Alice
// 25
// 4
// 1
// O'Brien
// 30
// 5
// 0
// Charlie
// true
// true
// true
// 1
// 26
// 1
// 2
// closed

import db

define getNil
    let x be 1
    // returns nil implicitly

let conn be db.open(":memory:")

// 1. CREATE TABLE
let createRes be conn.execute("CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, age INTEGER, rating REAL, flag INTEGER)", [])
show createRes

// 2. INSERT rows
let ins1 be conn.insert("INSERT INTO users (name, age, rating, flag) VALUES (?, ?, ?, ?)", ["Alice", 25, 4, true])
let ins2 be conn.insert("INSERT INTO users (name, age, rating, flag) VALUES (?, ?, ?, ?)", ["O'Brien", 30, 5, false])
let ins3 be conn.insert("INSERT INTO users (name, age, rating, flag) VALUES (?, ?, ?, ?)", ["Charlie", getNil(), getNil(), getNil()])
show ins1
show ins2
show ins3

// 3. SELECT rows
let rows be conn.query("SELECT * FROM users ORDER BY id ASC", [])
show rows.length()

let r1 be rows.get(0)
show r1.get("name")
show r1.get("age")
show r1.get("rating")
show r1.get("flag")

let r2 be rows.get(1)
show r2.get("name")
show r2.get("age")
show r2.get("rating")
show r2.get("flag")

let r3 be rows.get(2)
show r3.get("name")
show r3.get("age") == getNil()
show r3.get("rating") == getNil()
show r3.get("flag") == getNil()

// 4. UPDATE rows
let updRes be conn.update("UPDATE users SET age = ? WHERE name = ?", [26, "Alice"])
show updRes

let aliceRow be conn.query("SELECT age FROM users WHERE name = ?", ["Alice"])
show aliceRow.get(0).get("age")

// 5. DELETE rows
let delRes be conn.delete("DELETE FROM users WHERE name = ?", ["Charlie"])
show delRes

let rowsAfterDelete be conn.query("SELECT count(*) as cnt FROM users", [])
show rowsAfterDelete.get(0).get("cnt")

// 6. Close database
conn.close()
show "closed"
