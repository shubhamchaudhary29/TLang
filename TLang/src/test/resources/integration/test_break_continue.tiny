// Expected output:
// 1
// 2
// 3
// 4
// 1
// 2
// 4
// 5
// 0
// 1
// 3
// 4

// 1. break exiting a while loop early
let i be 0
while i < 10
    set i to i + 1
    if i == 5
        break
    show i

// 2. continue skipping an iteration in a while loop
let j be 0
while j < 5
    set j to j + 1
    if j == 3
        continue
    show j

// 3. continue inside a repeat loop specifically
repeat 5 times as k
    if k == 2
        continue
    show k
